<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0a0a0a;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; overflow: hidden;
        }
        .video-container {
            width: 400px; height: 711px;
            background: #000;
            position: relative; overflow: hidden;
            border-radius: 40px;
            box-shadow: 0 0 60px rgba(147, 51, 234, 0.3);
        }
        .scene {
            position: absolute;
            width: 100%; height: 100%;
            opacity: 0;
            transition: opacity 0.5s ease;
            overflow: hidden;
        }
        .scene.active { opacity: 1; }
        .scene-hook {
            background: radial-gradient(ellipse at center, #1e3c72 0%, #2a5298 100%);
            display: flex; flex-direction: column; justify-content: center; align-items: center;
        }
        .particles { position: absolute; width: 100%; height: 100%; }
        .particle {
            position: absolute; width: 4px; height: 4px;
            background: rgba(255, 255, 255, 0.8); border-radius: 50%;
            animation: float 10s infinite ease-in-out;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); opacity: 0; }
            10% { opacity: 1; } 90% { opacity: 1; }
            100% { transform: translateY(-100vh) translateX(50px); }
        }
        .hook-text { color: white; text-align: center; z-index: 2; padding: 40px; }
        .hook-text h1 { font-size: 2rem; font-weight: 800; margin-bottom: 16px; line-height: 1.2; animation: slideInScale 1s ease-out forwards; }
        .hook-text .subline { font-size: 1.1rem; opacity: 0.85; }
        @keyframes slideInScale {
            0% { transform: scale(0.9) translateY(30px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }
        .scene-content {
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 40px; color: white;
        }
        .scene-content.scene-bg-0 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .scene-content.scene-bg-1 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
        .scene-content.scene-bg-2 { background: #1a1a2e; }
        .content-card {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            padding: 36px; border-radius: 24px;
            text-align: center; max-width: 340px;
            animation: fadeInUp 0.8s ease-out forwards;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        }
        @keyframes fadeInUp {
            0% { transform: translateY(30px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }
        .content-card p { font-size: 1.2rem; line-height: 1.5; margin-bottom: 0.5rem; }
        .scene-cta {
            background: radial-gradient(circle at center, #ff0844 0%, #ffb199 100%);
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            color: white; text-align: center; padding: 40px;
        }
        .cta-title { font-size: 2rem; font-weight: 800; margin-bottom: 24px; animation: slideInLeft 1s ease-out; }
        .cta-sub { font-size: 1.2rem; margin-bottom: 24px; opacity: 0.95; }
        @keyframes slideInLeft {
            0% { transform: translateX(-40px); opacity: 0; }
            100% { transform: translateX(0); opacity: 1; }
        }
        .progress-bar {
            position: absolute; bottom: 0; width: 100%; height: 4px;
            background: rgba(255, 255, 255, 0.2);
        }
        .progress-fill { height: 100%; background: white; width: 0%; transition: width 0.3s linear; }
        .controls {
            position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
            display: flex; gap: 20px; z-index: 100;
        }
        .control-btn {
            width: 50px; height: 50px;
            background: rgba(255, 255, 255, 0.9);
            border: none; border-radius: 50%;
            cursor: pointer; font-size: 1.5rem;
            display: flex; align-items: center; justify-content: center;
            transition: transform 0.3s;
        }
        .control-btn:hover { transform: scale(1.1); }
        #narration { display: none; }
        .key-stat { font-size: 3rem; font-weight: 800; margin-bottom: 8px; opacity: 0; }
        .key-stat.animate { animation: countIn 1s ease-out forwards; }
        @keyframes countIn {
            0% { opacity: 0; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1); }
        }
        .stat-bar { width: 80%; max-width: 200px; height: 8px; background: rgba(255,255,255,0.3); border-radius: 4px; margin: 12px auto; overflow: hidden; }
        .stat-bar-fill { height: 100%; width: 0%; background: white; border-radius: 4px; transition: width 1s ease-out; }
        .stat-bar-fill.animate { width: 100%; }
        .content-bullets { list-style: none; text-align: left; margin-top: 20px; padding-left: 0; max-width: 300px; }
        .content-bullets li {
            opacity: 0; transform: translateX(-20px); animation: bulletIn 0.4s ease-out forwards;
            position: relative; padding-left: 1.25rem; margin-bottom: 0.6rem;
            line-height: 1.45; font-size: 1.05rem;
        }
        .content-bullets li::before {
            content: '\2022';
            position: absolute; left: 0; color: rgba(255,255,255,0.95);
            font-weight: 700; font-size: 1.2em;
        }
        .content-bullets li:nth-child(1) { animation-delay: 0.1s; }
        .content-bullets li:nth-child(2) { animation-delay: 0.25s; }
        .content-bullets li:nth-child(3) { animation-delay: 0.4s; }
        .content-bullets li:nth-child(4) { animation-delay: 0.55s; }
        .content-bullets li:nth-child(5) { animation-delay: 0.7s; }
        @keyframes bulletIn {
            0% { opacity: 0; transform: translateX(-20px); }
            100% { opacity: 1; transform: translateX(0); }
        }
        .scene-emoji { font-size: 2.5rem; margin-bottom: 12px; opacity: 0; }
        .scene-emoji.animate { animation: emojiPop 0.6s ease-out forwards; }
        @keyframes emojiPop {
            0% { opacity: 0; transform: scale(0); }
            70% { transform: scale(1.15); }
            100% { opacity: 1; transform: scale(1); }
        }
        .scene-image {
            position: absolute;
            bottom: 80px;
            right: 20px;
            width: 140px;
            height: 100px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(0,0,0,0.3);
            animation: figureSlideIn 0.8s ease-out forwards;
        }
        .scene-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .scene-image-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 6px 8px;
            font-size: 0.7rem;
            background: rgba(0,0,0,0.6);
            color: rgba(255,255,255,0.95);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        @keyframes figureSlideIn {
            0% { transform: translateX(40px); opacity: 0; }
            100% { transform: translateX(0); opacity: 1; }
        }
        .content-layout-figure-right {
            display: flex; flex-direction: row; align-items: center; justify-content: center;
            gap: 20px; width: 100%; padding: 24px; box-sizing: border-box;
        }
        .content-figure-right-text { flex: 1; min-width: 0; max-width: 55%; text-align: left; }
        .content-figure-right-text p { font-size: 1.1rem; line-height: 1.5; margin-bottom: 12px; }
        .content-figure-right-figure { flex-shrink: 0; width: 160px; border-radius: 12px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,0.25); animation: figureSlideIn 0.8s ease-out forwards; }
        .content-figure-right-figure img { width: 100%; height: auto; display: block; object-fit: cover; max-height: 180px; }
        .content-figure-right-caption { font-size: 0.65rem; padding: 4px 6px; background: rgba(0,0,0,0.5); color: rgba(255,255,255,0.9); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .content-layout-minimal { text-align: center; padding: 36px 32px; max-width: 340px; }
        .content-layout-minimal p { font-size: 1.35rem; line-height: 1.5; margin-bottom: 20px; font-weight: 500; }
        .content-layout-minimal .content-bullets { margin-left: auto; margin-right: auto; margin-top: 24px; }
    </style>
</head>
<body>
    <audio id="narration" src="{{ audio_src }}"></audio>
    <div class="video-container">
        {% for scene in scenes %}
        <div class="scene scene-{{ loop.index }} scene-{{ scene.slide_type }}{% if scene.slide_type == 'content' %} scene-bg-{{ (loop.index0 - 1) % 3 }}{% endif %}{% if loop.first %} active{% endif %}" data-scene-index="{{ loop.index }}">
            {% if scene.slide_type == 'hook' %}
            <div class="particles" id="particles-hook"></div>
            <div class="hook-text">
                <h1>{{ scene.text.split('.')[0] if '.' in scene.text else scene.text }}</h1>
                {% if '.' in scene.text %}<p class="subline">{{ scene.text.split('.', 1)[1].strip()[:120] }}</p>{% endif %}
            </div>
            {% elif scene.slide_type == 'content' %}
            {% set content_layout = 'figure-right' if scene.figure_url else ('card' if loop.index0 % 2 == 1 else 'minimal') %}
            {% if content_layout == 'card' %}
            <div class="content-card">
                {% if scene.key_stat %}
                <div class="scene-emoji" data-scene-index="{{ loop.index }}">📊</div>
                <div class="key-stat" data-target="{{ scene.key_stat }}" data-scene-index="{{ loop.index }}">0</div>
                <div class="stat-bar"><div class="stat-bar-fill" data-scene-index="{{ loop.index }}"></div></div>
                {% endif %}
                <p>{{ scene.text }}</p>
                {% if scene.bullets %}
                <ul class="content-bullets">
                    {% for bullet in scene.bullets %}
                    <li>{{ bullet }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
            {% if scene.figure_url %}
            <div class="scene-image">
                <img src="{{ scene.figure_url }}" alt="{{ scene.figure_caption or 'Figure' }}" loading="lazy" />
                {% if scene.figure_caption %}<div class="scene-image-caption">{{ scene.figure_caption[:80] }}{% if scene.figure_caption|length > 80 %}…{% endif %}</div>{% endif %}
            </div>
            {% endif %}
            {% elif content_layout == 'figure-right' %}
            <div class="content-layout-figure-right">
                <div class="content-figure-right-text">
                    <p>{{ scene.text }}</p>
                    {% if scene.bullets %}
                    <ul class="content-bullets">
                        {% for bullet in scene.bullets %}
                        <li>{{ bullet }}</li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </div>
                <div class="content-figure-right-figure">
                    <img src="{{ scene.figure_url }}" alt="{{ scene.figure_caption or 'Figure' }}" loading="lazy" />
                    {% if scene.figure_caption %}<div class="content-figure-right-caption">{{ scene.figure_caption[:60] }}{% if scene.figure_caption|length > 60 %}…{% endif %}</div>{% endif %}
                </div>
            </div>
            {% elif content_layout == 'minimal' %}
            <div class="content-layout-minimal">
                <p>{{ scene.text }}</p>
                {% if scene.bullets %}
                <ul class="content-bullets">
                    {% for bullet in scene.bullets %}
                    <li>{{ bullet }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
            {% endif %}
            {% elif scene.slide_type == 'cta' %}
            <h2 class="cta-title">{{ scene.text.split('.')[0] if '.' in scene.text else scene.text }}</h2>
            {% if '.' in scene.text %}<p class="cta-sub">{{ scene.text.split('.', 1)[1].strip()[:100] }}</p>{% endif %}
            <div class="cta-button">Learn more</div>
            {% endif %}
        </div>
        {% endfor %}
        <div class="progress-bar">
            <div class="progress-fill" id="progress" style="width: 0%;"></div>
        </div>
        <div class="controls">
            <button class="control-btn" id="playBtn" type="button" aria-label="Play">▶️</button>
        </div>
    </div>
    <script>
        (function() {
            var sceneDurations = {{ scene_durations | tojson }};
            var totalDuration = {{ total_duration | tojson }};
            var particlesContainer = document.getElementById('particles-hook');
            if (particlesContainer) {
                for (var i = 0; i < 25; i++) {
                    var p = document.createElement('div');
                    p.className = 'particle';
                    p.style.left = Math.random() * 100 + '%';
                    p.style.animationDelay = Math.random() * 8 + 's';
                    p.style.animationDuration = (10 + Math.random() * 10) + 's';
                    particlesContainer.appendChild(p);
                }
            }
            var scenes = document.querySelectorAll('.scene');
            var playBtn = document.getElementById('playBtn');
            var progress = document.getElementById('progress');
            var audioEl = document.getElementById('narration');
            var currentScene = 1;
            var currentTime = 0;
            var isPlaying = false;
            var interval = null;
            function parseStatTarget(str) {
                if (!str || typeof str !== 'string') return { num: 0, suffix: '' };
                var m = str.match(/^(\d+(?:\.\d+)?)\s*(.*)$/);
                if (m) return { num: parseFloat(m[1], 10), suffix: m[2] || '' };
                return { num: 0, suffix: str };
            }
            function runCountUp(el, targetStr, durationMs) {
                var start = 0;
                var parsed = parseStatTarget(targetStr);
                var end = parsed.num;
                var suffix = parsed.suffix;
                var startTime = null;
                function step(timestamp) {
                    if (!startTime) startTime = timestamp;
                    var elapsed = timestamp - startTime;
                    var t = Math.min(1, elapsed / durationMs);
                    var eased = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
                    var current = start + (end - start) * eased;
                    el.textContent = Math.round(current) + suffix;
                    if (t < 1) requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
            }
            function showScene(num) {
                currentScene = num;
                document.querySelectorAll('.key-stat.animate, .stat-bar-fill.animate, .scene-emoji.animate').forEach(function(el) {
                    el.classList.remove('animate');
                });
                scenes.forEach(function(s, i) {
                    var isActive = i + 1 === num;
                    s.classList.toggle('active', isActive);
                    if (isActive) {
                        var keyStat = s.querySelector('.key-stat');
                        var barFill = s.querySelector('.stat-bar-fill');
                        if (keyStat && keyStat.dataset.target) {
                            keyStat.textContent = '0' + (parseStatTarget(keyStat.dataset.target).suffix || '');
                            keyStat.classList.add('animate');
                            runCountUp(keyStat, keyStat.dataset.target, 1000);
                        }
                        if (barFill) {
                            barFill.classList.add('animate');
                        }
                        var emoji = s.querySelector('.scene-emoji');
                        if (emoji) {
                            emoji.classList.add('animate');
                        }
                    }
                });
            }
            function updateProgress() {
                var pct = totalDuration > 0 ? (currentTime / totalDuration) * 100 : 0;
                progress.style.width = Math.min(100, pct) + '%';
            }
            function play() {
                isPlaying = true;
                playBtn.textContent = '⏸️';
                playBtn.setAttribute('aria-label', 'Pause');
                if (audioEl && audioEl.src) {
                    audioEl.currentTime = currentTime;
                    audioEl.play().catch(function() {});
                }
                interval = setInterval(function() {
                    if (audioEl && !audioEl.paused) currentTime = audioEl.currentTime;
                    else currentTime += 0.1;
                    updateProgress();
                    var acc = 0;
                    for (var i = 0; i < sceneDurations.length; i++) {
                        acc += sceneDurations[i];
                        if (currentTime <= acc) {
                            if (currentScene !== i + 1) showScene(i + 1);
                            break;
                        }
                    }
                    if (currentTime >= totalDuration) {
                        clearInterval(interval);
                        interval = null;
                        isPlaying = false;
                        playBtn.textContent = '▶️';
                        playBtn.setAttribute('aria-label', 'Play');
                        if (audioEl) audioEl.pause();
                    }
                }, 100);
            }
            function pause() {
                isPlaying = false;
                playBtn.textContent = '▶️';
                playBtn.setAttribute('aria-label', 'Play');
                if (interval) { clearInterval(interval); interval = null; }
                if (audioEl) audioEl.pause();
            }
            function togglePlay() {
                if (isPlaying) pause(); else play();
            }
            playBtn.addEventListener('click', togglePlay);
            if (audioEl) {
                audioEl.addEventListener('ended', function() {
                    if (isPlaying) { pause(); currentTime = 0; currentScene = 1; showScene(1); updateProgress(); }
                });
            }
            showScene(1);
        })();
    </script>
</body>
</html>
