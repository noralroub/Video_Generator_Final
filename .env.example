# Copy to .env and fill in values.

# --- Always ---
DEBUG=True
SECRET_KEY=dev-secret-not-for-production
VIDEO_ACCESS_CODE=local

# --- Full run (real video generation) ---
# Get keys: https://aistudio.google.com/apikey (Gemini), https://anthropic.com (Claude)
# Runway is no longer required for the HTML pipeline (Claude + Playwright).
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: Claude model for script+HTML (default: claude-sonnet-4-20250514)
# CLAUDE_VIDEO_MODEL=claude-sonnet-4-20250514
RUNWAYML_API_SECRET=your-runway-api-secret
# Leave unset or False for real pipeline
SIMULATION_MODE=False

# Redis (defaults to below if unset; only needed for Celery)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
