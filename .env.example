# Copy to .env and fill in values.

# --- Always ---
DEBUG=True
SECRET_KEY=dev-secret-not-for-production
VIDEO_ACCESS_CODE=local

# --- Full run (real video generation) ---
# Get keys: https://aistudio.google.com/apikey (Gemini), https://runwayml.com (Runway)
GEMINI_API_KEY=your-gemini-api-key
RUNWAYML_API_SECRET=your-runway-api-secret
# Leave unset or False for real pipeline
SIMULATION_MODE=False

# Redis (defaults to below if unset; only needed for Celery)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
